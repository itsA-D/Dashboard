# API Configuration - Direct backend access from browser
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# Optional: when set, frontend calls backend directly from the browser.
NEXT_PUBLIC_API_URL=

# Used by Next.js server-side API proxy at /api/proxy (default path for this app).
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
